generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── ENUM NUEVO ───────────────────────────────────────────────────────────────

enum TipoPeso {
  FIJO
  VARIABLE
}

// ─── TENANT ──────────────────────────────────────────────────────────────────

model Tenant {
  id               Int       @id @default(autoincrement())
  nombre           String
  cif              String?   @unique
  email            String
  regionUE         Boolean   @default(true)  @map("region_ue")
  activo           Boolean   @default(true)
  plan             String    @default("basico")
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  notasInternas    String?   @map("notas_internas")
  // Suscripción vía Lemon Squeezy (license key)
  licenseKey        String?  @map("license_key")
  licenseInstanceId String?  @map("license_instance_id")
  licenseStatus     String?  @map("license_status")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")

  unidades    Unidad[]
  usuarios    Usuario[]
  productos   Producto[]
  categorias  Categoria[]
  proveedores Proveedor[]
  pedidos     Pedido[]
  inventario  Inventario[]
  movimientos Movimiento[]

  fichaCategories FichaCategoria[]
  insumos         Insumo[]
  preparaciones   Preparacion[]
  fichasTecnicas  FichaTecnica[]
  festivos        Festivo[]

  // ── Módulo Stock ─────────────────────────────────────────────────────────
  lotesInventario          LoteInventario[]
  consumosLote             ConsumoLote[]
  variantesProveedor       VarianteProveedor[]
  elaboraciones            Elaboracion[]
  ingredientesElaboracion  IngredienteElaboracion[]
  lotesElaboracion         LoteElaboracion[]
  insumosLoteElaboracion   InsumoLoteElaboracion[]
  consumosLoteElaboracion  ConsumoLoteElaboracion[]
  ingredientesPlatoStock   IngredientePlatoStock[]
  integracionTPV           IntegracionTPV?
  logsTPV                  LogLlamadaTPV[]

  @@map("tenants")
}

// ─── MODELOS DE NEGOCIO ───────────────────────────────────────────────────────

model Unidad {
  id          Int          @id @default(autoincrement())
  nombre      String
  direccion   String?
  responsable String?
  telefono    String?
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime?    @default(now()) @updatedAt @map("updated_at")
  tenantId    Int          @map("tenant_id")
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  usuarios    Usuario[]
  pedidos     Pedido[]
  inventario  Inventario[]
  movimientos Movimiento[]

  @@map("unidades")
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")
  tenantId  Int        @map("tenant_id")
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  productos Producto[]

  @@unique([tenantId, nombre])
  @@map("categorias")
}

model Proveedor {
  id        Int        @id @default(autoincrement())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at")
  tenantId  Int        @map("tenant_id")
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  productos Producto[]
  pedidos   Pedido[]

  @@map("proveedores")
}

model Producto {
  id             Int          @id @default(autoincrement())
  nombre         String
  fabricante     String?
  formato        String?
  categoriaId    Int          @map("categoria_id")
  proveedorId    Int?         @map("proveedor_id")
  unidadMedida   String       @map("unidad_medida")
  precioUnitario Decimal      @map("precio_unitario") @db.Decimal(10, 2)
  stockMinimo    Decimal      @map("stock_minimo") @db.Decimal(10, 2)
  contenidoNeto    Decimal? @map("contenido_neto") @db.Decimal(12, 3)
  contenidoUnidad  String?  @map("contenido_unidad")
  qrcode         String?      @map("qrcode")
  activo         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  tenantId       Int          @map("tenant_id")
  // ── Campos nuevos módulo Stock ─────────────────────────────────────────
  tipoPeso       TipoPeso     @default(FIJO) @map("tipo_peso")
  unidadBase     String?      @map("unidad_base")

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  categoria      Categoria    @relation(fields: [categoriaId], references: [id])
  proveedor      Proveedor?   @relation(fields: [proveedorId], references: [id])
  pedidoItems    PedidoItem[]
  inventario     Inventario[]
  movimientos    Movimiento[]
  insumos        Insumo[]

  // ── Relaciones módulo Stock ────────────────────────────────────────────
  lotes                    LoteInventario[]
  variantesProveedor       VarianteProveedor[]
  ingredienteElaboraciones IngredienteElaboracion[]
  ingredientesPlatoStock   IngredientePlatoStock[]

  @@unique([tenantId, qrcode])
  @@map("productos")
}

model Usuario {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String       @map("password_hash")
  nombre      String
  rol         String       @default("viewer")
  unidadId    Int?         @map("unidad_id")
  pinCode     String?      @map("pin_code")
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime?    @default(now()) @updatedAt @map("updated_at")
  tenantId    Int          @map("tenant_id")
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  unidad      Unidad?      @relation(fields: [unidadId], references: [id])
  pedidos     Pedido[]
  movimientos Movimiento[]
  recepciones PedidoItem[]

  fichasCreadas      FichaTecnica[] @relation("FichasCreadas")
  fichasActualizadas FichaTecnica[] @relation("FichasActualizadas")

  @@map("usuarios")
}

model Pedido {
  id             Int          @id @default(autoincrement())
  unidadId       Int          @map("unidad_id")
  usuarioId      Int          @map("usuario_id")
  proveedorId    Int?         @map("proveedor_id")
  fechaPedido    DateTime     @default(now()) @map("fecha_pedido")
  estado         String       @default("borrador")
  total          Decimal      @default(0) @db.Decimal(10, 2)
  notas          String?
  parentPedidoId Int?         @map("parent_pedido_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  tenantId       Int          @map("tenant_id")
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  unidad         Unidad       @relation(fields: [unidadId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  proveedor      Proveedor?   @relation(fields: [proveedorId], references: [id])
  parent         Pedido?      @relation("PedidoHijos", fields: [parentPedidoId], references: [id])
  hijos          Pedido[]     @relation("PedidoHijos")
  items          PedidoItem[]

  @@map("pedidos")
}

model PedidoItem {
  id               Int          @id @default(autoincrement())
  pedidoId         Int          @map("pedido_id")
  productoId       Int          @map("producto_id")
  cantidad         Decimal      @db.Decimal(10, 2)
  precioUnitario   Decimal      @map("precio_unitario") @db.Decimal(10, 2)
  cantidadRecibida Decimal      @default(0) @map("cantidad_recibida") @db.Decimal(10, 2)
  lote             String?
  fechaCaducidad   DateTime?    @map("fecha_caducidad")
  fechaRecepcion   DateTime?    @map("fecha_recepcion")
  recibidoPorId    Int?         @map("recibido_por_id")
  estadoLinea      String       @default("pendiente") @map("estado_linea")
  pedido           Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto         Producto     @relation(fields: [productoId], references: [id])
  recibidoPor      Usuario?     @relation(fields: [recibidoPorId], references: [id])
  movimientos      Movimiento[]

  @@map("pedido_items")
}

model Inventario {
  id             Int       @id @default(autoincrement())
  productoId     Int       @map("producto_id")
  cantidad       Decimal   @db.Decimal(10, 2)
  lote           String?
  fechaCaducidad DateTime? @map("fecha_caducidad")
  ubicacion      String?
  codigoUnico    String?   @map("codigo_unico")
  estado         String    @default("disponible")
  unidadId       Int       @map("unidad_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  tenantId       Int       @map("tenant_id")
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  producto       Producto  @relation(fields: [productoId], references: [id])
  unidad         Unidad    @relation(fields: [unidadId], references: [id])

  @@unique([tenantId, codigoUnico])
  @@map("inventario")
}

model Movimiento {
  id           Int         @id @default(autoincrement())
  productoId   Int         @map("producto_id")
  tipo         String
  cantidad     Decimal     @db.Decimal(10, 2)
  usuarioId    Int         @map("usuario_id")
  fecha        DateTime    @default(now())
  lote         String?
  notas        String?
  unidadId     Int         @map("unidad_id")
  pedidoItemId Int?        @map("pedido_item_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  tenantId     Int         @map("tenant_id")
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  producto     Producto    @relation(fields: [productoId], references: [id])
  usuario      Usuario     @relation(fields: [usuarioId], references: [id])
  unidad       Unidad      @relation(fields: [unidadId], references: [id])
  pedidoItem   PedidoItem? @relation(fields: [pedidoItemId], references: [id])

  @@map("movimientos")
}

model ConfigEtiqueta {
  id        Int      @id @default(1)
  titulo    String   @default("CHEFMANAGER PRO")
  altoLabel Int      @default(417) @map("alto_label")
  xMargen   Int      @default(15)  @map("x_margen")
  espaciado Int      @default(38)
  fuente    Int      @default(4)
  xQR       Int      @default(205) @map("x_qr")
  yQR       Int      @default(300) @map("y_qr")
  tamanoQR  Int      @default(3)   @map("tamano_qr")
  updatedAt DateTime @updatedAt    @map("updated_at")

  @@map("config_etiqueta")
}

// ─── MÓDULO FICHAS TÉCNICAS ──────────────────────────────────────────────────

model FichaCategoria {
  id        Int            @id @default(autoincrement())
  nombre    String
  createdAt DateTime       @default(now()) @map("created_at")
  tenantId  Int            @map("tenant_id")
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  fichas    FichaTecnica[]

  @@unique([tenantId, nombre])
  @@map("ficha_categorias")
}

model Insumo {
  id             Int      @id @default(autoincrement())
  nombre         String
  unidad         String
  valorPorUnidad Float    @default(0) @map("valor_por_unidad")
  esPreparacion  Boolean  @default(false) @map("es_preparacion")
  preparacionId  Int?     @map("preparacion_id")
  productoId     Int?     @map("producto_id")
  createdAt      DateTime @default(now()) @map("created_at")
  tenantId       Int      @map("tenant_id")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  preparacion Preparacion? @relation("InsumoGenerado", fields: [preparacionId], references: [id])
  producto    Producto?    @relation(fields: [productoId], references: [id])

  fichaIngredientes       FichaIngrediente[]
  preparacionIngredientes PreparacionIngrediente[]

  @@unique([tenantId, productoId])
  @@map("insumos")
}

model Preparacion {
  id              Int      @id @default(autoincrement())
  nombre          String
  porciones       Float
  costoTotal      Float    @default(0) @map("costo_total")
  costoPorPorcion Float    @default(0) @map("costo_por_porcion")
  procedimiento   String?
  createdAt       DateTime @default(now()) @map("created_at")
  tenantId        Int      @map("tenant_id")

  tenant         Tenant                   @relation(fields: [tenantId], references: [id])
  ingredientes   PreparacionIngrediente[]
  insumoGenerado Insumo[]                 @relation("InsumoGenerado")

  @@map("preparaciones")
}

model PreparacionIngrediente {
  id            Int   @id @default(autoincrement())
  preparacionId Int   @map("preparacion_id")
  insumoId      Int   @map("insumo_id")
  cantidad      Float

  preparacion Preparacion @relation(fields: [preparacionId], references: [id], onDelete: Cascade)
  insumo      Insumo      @relation(fields: [insumoId], references: [id])

  @@map("preparacion_ingredientes")
}

model FichaTecnica {
  id               Int      @id @default(autoincrement())
  nombre           String
  categoriaId      Int?     @map("categoria_id")
  descripcion      String?
  porciones        Float    @default(1)
  tiempoMin        Int      @default(0) @map("tiempo_min")
  urlImagen        String?  @map("url_imagen")
  alergenos        String[] @default([])
  procedimiento    String?
  costoTotal       Float    @default(0) @map("costo_total")
  costoPorPorcion  Float    @default(0) @map("costo_por_porcion")
  creadoPorId      Int?     @map("creado_por_id")
  actualizadoPorId Int?     @map("actualizado_por_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  tenantId         Int      @map("tenant_id")

  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  categoria             FichaCategoria?         @relation(fields: [categoriaId], references: [id])
  creadoPor             Usuario?                @relation("FichasCreadas", fields: [creadoPorId], references: [id])
  actualizadoPor        Usuario?                @relation("FichasActualizadas", fields: [actualizadoPorId], references: [id])
  ingredientes          FichaIngrediente[]
  ingredientesPlatoStock IngredientePlatoStock[]

  @@map("fichas_tecnicas")
}

model FichaIngrediente {
  id             Int   @id @default(autoincrement())
  fichaId        Int   @map("ficha_id")
  insumoId       Int   @map("insumo_id")
  cantidad       Float
  costoCalculado Float @default(0) @map("costo_calculado")

  ficha  FichaTecnica @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  insumo Insumo       @relation(fields: [insumoId], references: [id])

  @@map("ficha_ingredientes")
}

// ─── MÓDULO PREDICCIONES ─────────────────────────────────────────────────────

model Festivo {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @db.Date
  nombre    String
  factor    Float    @default(1.25)
  createdAt DateTime @default(now()) @map("created_at")
  tenantId  Int      @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, fecha, nombre])
  @@map("festivos")
}

// ─── MÓDULO STOCK ─────────────────────────────────────────────────────────────
// Reglas críticas:
// - Solo migraciones aditivas (ADD COLUMN, ADD TABLE)
// - Stock insuficiente nunca lanza excepción — devuelve flag
// - Toda entidad nueva lleva tenantId

// ── Migración 1a ─────────────────────────────────────────────────────────────

model LoteInventario {
  id              Int       @id @default(autoincrement())
  tenantId        Int       @map("tenant_id")
  productoId      Int       @map("producto_id")
  fechaEntrada    DateTime  @default(now()) @map("fecha_entrada")
  fechaCaducidad  DateTime? @map("fecha_caducidad")
  cantidadInicial Float     @map("cantidad_inicial")
  cantidadActual  Float     @map("cantidad_actual")
  pesoRealKg      Float?    @map("peso_real_kg")
  numeroLote      String?   @map("numero_lote")
  codigoUnico     String?   @map("codigo_unico")
  ubicacion       String?
  agotado         Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  producto           Producto                @relation(fields: [productoId], references: [id])
  consumos           ConsumoLote[]
  insumosElaboracion InsumoLoteElaboracion[]

  @@index([tenantId, productoId, agotado, fechaEntrada])
  @@index([tenantId, codigoUnico])
  @@map("lotes_inventario")
}

model ConsumoLote {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  loteId       Int      @map("lote_id")
  cantidad     Float
  motivo       String
  referenciaId String?  @map("referencia_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  lote   LoteInventario @relation(fields: [loteId], references: [id])

  @@index([tenantId, loteId])
  @@index([tenantId, motivo])
  @@map("consumos_lote")
}

// ── Migración 1b ─────────────────────────────────────────────────────────────

model VarianteProveedor {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @map("tenant_id")
  productoId       Int      @map("producto_id")
  nombre           String
  factorConversion Float    @map("factor_conversion")
  activa           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([productoId, tenantId, nombre])
  @@index([tenantId, productoId])
  @@map("variantes_proveedor")
}

// ── Migración 1c ─────────────────────────────────────────────────────────────

model Elaboracion {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  nombre      String
  descripcion String?
  unidadBase  String   @map("unidad_base")
  stockMinimo Float?   @map("stock_minimo")
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  ingredientes      IngredienteElaboracion[]
  lotes             LoteElaboracion[]
  ingredientesPlato IngredientePlatoStock[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("elaboraciones")
}

model IngredienteElaboracion {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @map("tenant_id")
  elaboracionId Int      @map("elaboracion_id")
  productoId    Int      @map("producto_id")
  cantidad      Float
  unidad        String
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  elaboracion Elaboracion @relation(fields: [elaboracionId], references: [id], onDelete: Cascade)
  producto    Producto    @relation(fields: [productoId], references: [id])

  @@index([tenantId, elaboracionId])
  @@map("ingredientes_elaboracion")
}

model LoteElaboracion {
  id              Int       @id @default(autoincrement())
  tenantId        Int       @map("tenant_id")
  elaboracionId   Int       @map("elaboracion_id")
  fechaProduccion DateTime  @default(now()) @map("fecha_produccion")
  fechaCaducidad  DateTime? @map("fecha_caducidad")
  cantidadInicial Float     @map("cantidad_inicial")
  cantidadActual  Float     @map("cantidad_actual")
  agotado         Boolean   @default(false)
  notas           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  elaboracion Elaboracion              @relation(fields: [elaboracionId], references: [id])
  insumos     InsumoLoteElaboracion[]
  consumos    ConsumoLoteElaboracion[]

  @@index([tenantId, elaboracionId, agotado, fechaProduccion])
  @@map("lotes_elaboracion")
}

model InsumoLoteElaboracion {
  id                Int      @id @default(autoincrement())
  tenantId          Int      @map("tenant_id")
  loteElaboracionId Int      @map("lote_elaboracion_id")
  loteInventarioId  Int      @map("lote_inventario_id")
  cantidadUsada     Float    @map("cantidad_usada")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  loteElaboracion LoteElaboracion @relation(fields: [loteElaboracionId], references: [id])
  loteInventario  LoteInventario  @relation(fields: [loteInventarioId], references: [id])

  @@index([tenantId, loteElaboracionId])
  @@index([tenantId, loteInventarioId])
  @@map("insumos_lote_elaboracion")
}

model ConsumoLoteElaboracion {
  id                Int      @id @default(autoincrement())
  tenantId          Int      @map("tenant_id")
  loteElaboracionId Int      @map("lote_elaboracion_id")
  cantidad          Float
  motivo            String
  referenciaId      String?  @map("referencia_id")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  loteElaboracion LoteElaboracion @relation(fields: [loteElaboracionId], references: [id])

  @@index([tenantId, loteElaboracionId])
  @@map("consumos_lote_elaboracion")
}

// Ingredientes de FichaTecnica con vínculos directos a Producto/Elaboracion
// para el motor de consumo de stock TPV. Coexiste con FichaIngrediente/Insumo.
model IngredientePlatoStock {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @map("tenant_id")
  fichaId       Int      @map("ficha_id")
  productoId    Int?     @map("producto_id")
  elaboracionId Int?     @map("elaboracion_id")
  cantidad      Float
  unidad        String
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  ficha       FichaTecnica  @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  producto    Producto?     @relation(fields: [productoId], references: [id])
  elaboracion Elaboracion?  @relation(fields: [elaboracionId], references: [id])

  @@index([tenantId, fichaId])
  @@map("ingredientes_plato_stock")
}

// ── Migración 1d ─────────────────────────────────────────────────────────────

model IntegracionTPV {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @unique @map("tenant_id")
  apiKey    String   @unique @default(uuid()) @map("api_key")
  activa    Boolean  @default(true)
  nombre    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  logs   LogLlamadaTPV[]

  @@index([tenantId])
  @@map("integraciones_tpv")
}

model LogLlamadaTPV {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @map("tenant_id")
  integracionId Int      @map("integracion_id")
  fichaId       Int?     @map("ficha_id")
  cantidadPlatos Float?  @map("cantidad_platos")
  statusCode    Int      @map("status_code")
  ok            Boolean
  payload       Json
  respuesta     Json
  ipOrigen      String?  @map("ip_origen")
  duracionMs    Int?     @map("duracion_ms")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  integracion IntegracionTPV @relation(fields: [integracionId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, ok])
  @@map("logs_llamada_tpv")
}
